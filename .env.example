# Email backend: "imap" or "gmail"
EMAIL_BACKEND=imap

# IMAP Configuration (when EMAIL_BACKEND=imap)
IMAP_HOST=imap.example.com
IMAP_USER=user@example.com
IMAP_PASSWORD=your-password-here
IMAP_PORT=993
IMAP_USE_SSL=true
IMAP_FOLDERS=INBOX,Sent

# Gmail API Configuration (when EMAIL_BACKEND=gmail)
# Download credentials.json from Google Cloud Console > APIs & Credentials > OAuth 2.0 Client IDs
GMAIL_CREDENTIALS_PATH=data/gmail_credentials.json
GMAIL_TOKEN_PATH=data/gmail_token.json
# Comma-separated Gmail label IDs to sync (empty = all mail)
GMAIL_LABELS=

# AI Backend: "claude", "claude-cli", or "ollama"
AI_BACKEND=claude

# Claude API (when AI_BACKEND=claude)
ANTHROPIC_API_KEY=sk-ant-...

# Claude CLI (when AI_BACKEND=claude-cli)
# Uses the `claude` CLI tool — no API key needed, uses your CLI auth
# CLAUDE_MODEL can override the model used

# Ollama (local)
OLLAMA_MODEL=llama3.1:8b
OLLAMA_URL=http://localhost:11434

# Pipeline
AI_BATCH_SIZE=10

# Database
DB_PATH=data/email_manager.db
